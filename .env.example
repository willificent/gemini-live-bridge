# Gemini Live API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LIVE_URL=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1beta.GenerativeService.BidiGenerateContent
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenClaw Gateway Configuration
# Optional: Only required if using OpenClaw bridge
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here
OPENCLAW_SESSION_KEY=agent:main:voice
